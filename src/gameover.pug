extends header.pug

block content
    main.container.center-align
      .row
        .col.s12.m12
          .card.blue-grey.darken-1
            .progress
              .determinate(style='width: 100%')
            .card-content.white-text
              span.card-title Parabéns
              p Você acertou 20/25
              #piechart
            .card-action
              a.waves-effect.waves-light.btn.blue.darken-3(href='index.html') Inicio
    
    block append scripts
        script(type='text/javascript', src='https://www.gstatic.com/charts/loader.js')
        script(type='text/javascript', src='js/chart.js')
