extends layout.pug

block content
    main.container.center-align
      .row
        .col.s12.m12
          .card-panel.teal
            span.white-text.left 
                span#questionpage 1 
                span &nbsp;- 
                span#totalquestion 25
            span.white-text.right#time 12:00
            .progress
              .determinate.red
          .card.blue-grey.darken-1
            .progress
                .determinate#progressbar
            .card-content.white-text
              span.card-title Questão
              .left-align#answers Respostas
            .card-action
              button.left.waves-effect.waves-light.btn.blue.darken-1(disabled='disabled')#anterior Anterior
              button.waves-effect.waves-light.btn.blue.darken-3#proxima Proxima
              a.right.waves-effect.waves-light.btn.red(href='gameover.html') Finalizar
    block append scripts
        script(src='https://www.gstatic.com/firebasejs/4.5.1/firebase.js')
        script(src='js/firebase-list.js')
