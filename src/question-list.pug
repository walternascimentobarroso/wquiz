extends layout.pug

block content
    nav
        .nav-wrapper
            .col.s12
                a.breadcrumb(href='#!') Administração
                a.breadcrumb(href='#!') Lista de Questões
    main.container.center-align
        .row
            .col.s12.m12
                .card
                    .card-content
                        span.card-title 
                            a(href="question-add.html")
                                i.material-icons.left.green-text.text-accent-4 add_circle_outline
                            span Questões
                        table
                            thead
                                tr
                                    th #
                                    th Questão
                                    th Ver
                                    th Editar
                                    th Excluir
                            tbody
    block append scripts
        script(src='https://www.gstatic.com/firebasejs/4.5.1/firebase.js')
        script(src='js/firebase-admin-list.js')
