COMPOSE_PROJECT_NAME=wquiz

# Ports
API_PORT=8000
FRONTEND_PORT=5173
ADMIN_PORT=5174
POSTGRES_PORT=5432

# Local Postgres (Docker Compose service `db`)
POSTGRES_USER=wquiz
POSTGRES_PASSWORD=wquiz
POSTGRES_DB=wquiz

# Backend
SECRET_KEY=wquiz-dev-secret-change-in-production
DATABASE_URL=postgresql+psycopg://wquiz:wquiz@db:5432/wquiz
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
SESSION_TIME_LIMIT_MINUTES=120
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Frontends (baked at build time)
VITE_API_URL=http://localhost:8000

# --- Production reference (do NOT put secrets here) ---
# Copy to .env.production (gitignored) for Render:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME
# Prefer the External Database URL from Render when connecting from outside
# the Render private network. Internal hostnames (dpg-…-a) only work on Render.
# CORS_ORIGINS=["https://YOUR-APP.vercel.app"]
# SECRET_KEY=<long-random-string>
